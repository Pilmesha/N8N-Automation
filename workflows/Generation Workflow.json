      "parameters": {
        "jsCode": "const binaryData = items[0].binary || {};\nconst results = [];\n\nfor (const key of Object.keys(binaryData)) {\n  const file = binaryData[key];\n  \n  if (file.mimeType === 'application/pdf') {\n    results.push({\n      json: { \n        fileName: file.fileName,\n        sender: items[0].json.from,\n        has_pdfs: true \n      },\n      binary: {\n        data: file \n      }\n    });\n  }\n}\n\n// If no PDFs, return one item with the flag but NO binary 'data' key\nif (results.length === 0) {\n  return [{ \n    json: { \n      has_pdfs: false, \n      sender: items[0].json.from \n    },\n    binary: {}\n  }];\n}\n\nreturn results;"
      },
