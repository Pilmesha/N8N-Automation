# --- n8n Setup ---
N8N_ENCRYPTION_KEY=generate_a_random_string_here

# --- AI Credentials ---
# Get your key at https://aistudio.google.com/
GOOGLE_API_KEY=your_gemini_api_key_here

# --- Email Integration (IMAP/SMTP) ---
# For Gmail, use an "App Password"
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password_here
EMAIL_HOST_IMAP=imap.gmail.com
EMAIL_HOST_SMTP=smtp.gmail.com

# --- Google Sheets Service Account ---
# The JSON key from your Google Cloud Console
GOOGLE_SERVICE_ACCOUNT_INFO={...your_service_account_json_content...}
